   "source": [
    "# Perform RFM Analysis\n",
    "print(\"🔄 Performing RFM (Recency, Frequency, Monetary) Analysis...\")\n",
    "\n",
    "def perform_rfm_analysis(df):\n",
    "    \"\"\"\n",
    "    Perform RFM analysis on customer data.\n",
    "    \"\"\"\n",
    "    df_rfm = df.copy()\n",
    "    \n",
    "    # Calculate RFM metrics\n",
    "    # Recency: Simulate days since last transaction\n",
    "    np.random.seed(42)\n",
    "    df_rfm['recency'] = np.random.exponential(30, len(df_rfm))  # Average 30 days\n",
    "    \n",
    "    # Frequency: Annual transaction frequency\n",
    "    df_rfm['frequency'] = df_rfm['monthly_transactions'] * 12\n",
    "    \n",
    "    # Monetary: Total relationship value (balance + annual savings)\n",
    "    df_rfm['monetary'] = df_rfm['account_balance'] + (df_rfm['annual_income'] * 0.1)\n",
    "    \n",
    "    # Calculate RFM scores (1-5 scale)\n",
    "    df_rfm['R_score'] = pd.qcut(df_rfm['recency'], q=5, labels=[5,4,3,2,1], duplicates='drop')\n",
    "    df_rfm['F_score'] = pd.qcut(df_rfm['frequency'], q=5, labels=[1,2,3,4,5], duplicates='drop')\n",
    "    df_rfm['M_score'] = pd.qcut(df_rfm['monetary'], q=5, labels=[1,2,3,4,5], duplicates='drop')\n",
    "    \n",
    "    # Convert to numeric\n",
    "    df_rfm['R_score'] = pd.to_numeric(df_rfm['R_score'], errors='coerce')\n",
    "    df_rfm['F_score'] = pd.to_numeric(df_rfm['F_score'], errors='coerce')\n",
    "    df_rfm['M_score'] = pd.to_numeric(df_rfm['M_score'], errors='coerce')\n",
    "    \n",
    "    # Create RFM segments based on scores\n",
    "    def rfm_segment(row):\n",
    "        if row['R_score'] >= 4 and row['F_score'] >= 4 and row['M_score'] >= 4:\n",
    "            return 'Champions'\n",
    "        elif row['R_score'] >= 3 and row['F_score'] >= 3 and row['M_score'] >= 3:\n",
    "            return 'Loyal Customers'\n",
    "        elif row['R_score'] >= 3 and row['F_score'] >= 2:\n",
    "            return 'Potential Loyalists'\n",
    "        elif row['R_score'] >= 4 and row['F_score'] <= 2:\n",
    "            return 'New Customers'\n",
    "        elif row['R_score'] <= 2 and row['F_score'] >= 3:\n",
    "            return 'At Risk'\n",
    "        elif row['R_score'] <= 2 and row['F_score'] <= 2 and row['M_score'] >= 3:\n",
    "            return 'Cannot Lose Them'\n",
    "        elif row['R_score'] <= 2 and row['F_score'] <= 2 and row['M_score'] <= 2:\n",
    "            return 'Lost Customers'\n",
    "        else:\n",
    "            return 'Others'\n",
    "    \n",
    "    df_rfm['rfm_segment'] = df_rfm.apply(rfm_segment, axis=1)\n",
    "    \n",
    "    return df_rfm\n",
    "\n",
    "# Apply RFM analysis\n",
    "df_rfm = perform_rfm_analysis(df_processed)\n",
