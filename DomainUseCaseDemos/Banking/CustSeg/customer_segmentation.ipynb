    "## Data Preprocessing\n",
    "\n",
    "Before performing segmentation, we need to preprocess the data by handling missing values, creating derived features, and scaling numerical variables."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Data preprocessing function\n",
    "def preprocess_customer_data(df):\n",
    "    \"\"\"\n",
    "    Preprocess customer data for segmentation analysis.\n",
    "    \"\"\"\n",
    "    df_processed = df.copy()\n",
    "    \n",
    "    # Handle missing values (if any)\n",
    "    numeric_columns = df_processed.select_dtypes(include=[np.number]).columns\n",
    "    df_processed[numeric_columns] = df_processed[numeric_columns].fillna(df_processed[numeric_columns].median())\n",
    "    \n",
    "    # Create derived features\n",
    "    df_processed['income_to_balance_ratio'] = df_processed['annual_income'] / (df_processed['account_balance'] + 1)\n",
    "    df_processed['products_per_tenure'] = df_processed['num_products'] / (df_processed['tenure_years'] + 1)\n",
    "    df_processed['clv_per_year'] = df_processed['customer_lifetime_value'] / (df_processed['tenure_years'] + 1)\n",
    "    df_processed['transaction_frequency'] = df_processed['monthly_transactions'] * 12\n",
    "    \n",
    "    # Create categorical features\n",
    "    df_processed['age_group'] = pd.cut(df_processed['age'], \n",
    "                                     bins=[0, 30, 45, 60, 100], \n",
    "                                     labels=['Young', 'Middle', 'Senior', 'Elder'])\n",
    "    \n",
    "    df_processed['income_tier'] = pd.qcut(df_processed['annual_income'], \n",
    "                                        q=4, \n",
    "                                        labels=['Low', 'Medium', 'High', 'Premium'])\n",
    "    \n",
    "    return df_processed\n",
    "\n",
    "# Apply preprocessing\n",
    "df_processed = preprocess_customer_data(df)\n",
    "\n",
    "print(\"✅ Data preprocessing completed!\")\n",
    "print(f\"📊 New dataset shape: {df_processed.shape}\")\n",
    "print(f\"🆕 Added features: {set(df_processed.columns) - set(df.columns)}\")\n",
    "\n",
    "# Display processed data sample\n",
    "df_processed.head()"
   ]
